# Orika CLI live stream settings. Do not commit real credentials.
ORIKA_WS_URL=wss://auttrading.com:86
ORIKA_LOGIN=<your-login>
ORIKA_PASSWORD=<your-password>
ORIKA_SERIAL_NO=*
ORIKA_STREAM_MODE=all
ORIKA_OUTPUT_DIR=orika_live_output
ORIKA_STATE_FILE=
ORIKA_SNAPSHOT_INTERVAL=300
ORIKA_SKIP_TLS_VERIFY=1
